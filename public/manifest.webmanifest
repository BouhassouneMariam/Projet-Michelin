      "icons": [
        {
          "src": "/icons/pwa-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Carte",
      "short_name": "Carte",
      "description": "Afficher les restaurants Michelin autour de toi.",
      "url": "/map",
      "icons": [
        {
          "src": "/icons/pwa-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ]
