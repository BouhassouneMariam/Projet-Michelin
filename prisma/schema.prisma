generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BudgetLevel {
  LOW
  MEDIUM
  HIGH
  LUXURY
}

enum MichelinAward {
  SELECTED
  BIB_GOURMAND
  ONE_STAR
  TWO_STARS
  THREE_STARS
  GREEN_STAR
}


enum TagType {
  MOOD
  VIBE
  CUISINE
  OCCASION
  FEATURE
}

enum Role {
  USER
  ADMIN
}

model User {
  id           String  @id @default(cuid())
  name         String
  username     String  @unique
  avatarUrl    String?
  bio          String?
  isPublic     Boolean @default(true)
  isAmbassador Boolean @default(false)
  passwordHash String
  role         Role    @default(USER)

  collections Collection[]
  likes       RestaurantLike[]
  badges      UserBadge[]

  following Follow[] @relation("Follower")
  followers Follow[] @relation("Followed")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Restaurant {
  id          String         @id @default(cuid())
  name        String
  description String?
  city        String
  district    String?
  country     String?
  address     String?
  latitude    Float?
  longitude   Float?
  imageUrl    String?
  cuisine     String?
  chefName    String?
  priceLabel  String?
  budget      BudgetLevel
  award       MichelinAward @default(SELECTED)
  source      String?
  sourceUrl   String?
  externalId  String?        @unique

  tags            RestaurantTag[]
  collectionItems CollectionItem[]
  likes           RestaurantLike[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([city])
  @@index([budget])
  @@index([award])
}

model Tag {
  id   String  @id @default(cuid())
  name String
  slug String  @unique
  type TagType

  restaurants RestaurantTag[]
}

model RestaurantTag {
  restaurantId String
  tagId        String

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tag        Tag        @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([restaurantId, tagId])
}

model Collection {
  id          String  @id @default(cuid())
  title       String
  description String?
  coverUrl    String?
  isPublic    Boolean @default(true)

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  items CollectionItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

model CollectionItem {
  id           String  @id @default(cuid())
  collectionId String
  restaurantId String
  note         String?

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([collectionId, restaurantId])
}

model RestaurantLike {
  id           String @id @default(cuid())
  userId       String
  restaurantId String

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, restaurantId])
  @@index([restaurantId])
}

model Follow {
  id         String @id @default(cuid())
  followerId String
  followedId String

  follower User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  followed User @relation("Followed", fields: [followedId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([followerId, followedId])
  @@index([followedId])
}

model Badge {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?
  icon        String?

  users UserBadge[]
}

model UserBadge {
  userId  String
  badgeId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  earnedAt DateTime @default(now())

  @@id([userId, badgeId])
}

model Question {
  id        String           @id @default(cuid())
  key       String           @unique
  label     String
  question  String
  intro     String?
  options   QuestionOption[]
  order     Int              @default(0)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model QuestionOption {
  id          String   @id @default(cuid())
  label       String
  value       String
  description String?
  iconName    String?  @default("Sparkles")
  questionId  String
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
